{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "Lưu trữ thông tin chi tiết khách hàng.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "group": { "type": "string", "enum": ["Vũ trụ", "Thân thiết", "Mới", "Tiềm năng"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "PurchaseHistory": {
      "title": "Purchase History",
      "description": "Lịch sử mua hàng của khách hàng.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "productName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Completed", "Pending", "Cancelled"] }
      },
      "required": ["customerId", "productName", "amount", "date"]
    },
    "Campaign": {
      "title": "Marketing Campaign",
      "description": "Chiến dịch marketing gửi qua Email, SMS, Zalo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "channel": { "type": "string", "enum": ["Email", "SMS", "Zalo"] },
        "targetGroup": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Draft", "Scheduled", "Sent"] }
      },
      "required": ["title", "content", "channel"]
    }
  },
  "firestore": {
    "/customers": {
      "schema": "Customer",
      "description": "Danh sách khách hàng chính."
    },
    "/customers/{customerId}/purchases": {
      "schema": "PurchaseHistory",
      "description": "Lịch sử giao dịch của từng khách hàng."
    },
    "/campaigns": {
      "schema": "Campaign",
      "description": "Lịch sử các chiến dịch marketing."
    }
  }
}
